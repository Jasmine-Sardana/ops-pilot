# ops-pilot environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── LLM provider (pick one) ───────────────────────────────────────────────────

# Option A — Anthropic direct API (default)
# Get an API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Option B — AWS Bedrock
# Uncomment and set LLM_PROVIDER=bedrock, then configure AWS credentials below.
# The model value must be a Bedrock model ID (not a short Claude name).
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
# CLAUDE_MODEL=anthropic.claude-sonnet-4-5-20251001-v1:0
#
# AWS credentials — choose one approach:
#   a) Set env vars directly:
#      AWS_ACCESS_KEY_ID=AKIA...
#      AWS_SECRET_ACCESS_KEY=...
#   b) Use a named profile from ~/.aws/credentials:
#      AWS_PROFILE=my-profile
#   c) Run on AWS compute (EC2/ECS/Lambda) — IAM role is picked up automatically

# ── GitHub ────────────────────────────────────────────────────────────────────

# Classic PAT with `repo` + `workflow` scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── Slack (pick one) ──────────────────────────────────────────────────────────

# Option A — bot token (recommended): posts to any channel
# Create a Slack app at https://api.slack.com/apps, add chat:write scope
SLACK_BOT_TOKEN=xoxb-...

# Option B — incoming webhook (simpler): single channel only
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Optional overrides ────────────────────────────────────────────────────────

# Set to false to run live agents instead of pre-recorded scenarios
DEMO_MODE=true

# Override the default Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Path to a custom config file (default: ops-pilot.yml in current directory)
# OPS_PILOT_CONFIG=/path/to/ops-pilot.yml
